#!/bin/bash
echo "systemd-sysv hold" | dpkg --set-selections
echo "systemd hold" | dpkg --set-selections
dpkg --force-all -r systemd-sysv 2>/dev/null || true
apt-get install -y --no-install-recommends \
    -o APT::Force-LoopBreak=1 \
    -o Dpkg::Options::="--force-all" \
    openrc sysvinit-core
dpkg --force-all -r systemd 2>/dev/null || true
apt-get -f install -y 2>/dev/null || true
