#!/bin/bash
cat > /etc/os-release << OSEOF
PRETTY_NAME="BorealOS"
NAME="BorealOS"
ID=borealoOS
ID_LIKE=debian
HOME_URL="https://borealoOS.org"
SUPPORT_URL="https://borealoOS.org"
BUG_REPORT_URL="https://borealoOS.org"
OSEOF

cat > /etc/issue << ISEOF
BorealOS \n \l
ISEOF

cat > /etc/issue.net << ISEOF
BorealOS
ISEOF

cat > /etc/hostname << HEOF
BorealOS
HEOF

if [ -f /etc/default/grub ]; then
    sed -i 's/GRUB_DISTRIBUTOR=.*/GRUB_DISTRIBUTOR="BorealOS"/' /etc/default/grub
    update-grub 2>/dev/null || true
fi

for f in /usr/share/grub/themes/*/theme.txt /boot/grub/themes/*/theme.txt; do
    [ -f "$f" ] && sed -i 's/Debian/BorealOS/g' "$f"
done

for f in /usr/share/plymouth/themes/*/; do
    [ -f "$f/plymouth.script" ] && sed -i 's/Debian/BorealOS/g' "$f/plymouth.script"
done

mkdir -p /usr/share/sddm/themes/breeze
cat > /usr/share/sddm/themes/breeze/theme.conf.user << SEOF
[General]
background=/usr/share/backgrounds/borealoOS-wallpaper.png
SEOF

mkdir -p /etc/skel/.config
cat > /etc/skel/.config/plasma-org.kde.plasma.desktop-appletsrc << KEOF
[Containments][1][Wallpaper][org.kde.image][General]
Image=file:///usr/share/backgrounds/borealoOS-wallpaper.png
KEOF

cp /usr/share/pixmaps/borealoس.svg /usr/share/pixmaps/debian-logo.svg 2>/dev/null || true
cp /usr/share/pixmaps/borealoس.svg /usr/share/pixmaps/debian-logo.png 2>/dev/null || true
cp /usr/share/pixmaps/borealoس.svg /usr/share/pixmaps/logo.svg 2>/dev/null || true

find /usr/share/grub /boot/grub -name "*.cfg" 2>/dev/null | xargs sed -i 's/Debian GNU\/Linux/BorealOS/g' 2>/dev/null || true
find /usr/share/grub /boot/grub -name "*.cfg" 2>/dev/null | xargs sed -i 's/Debian/BorealOS/g' 2>/dev/null || true
